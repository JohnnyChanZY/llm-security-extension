# 数据库配置
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/llm_security

# NVD API Key (可选，有Key时请求间隔0.6秒，无Key时6秒)
# 申请地址: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# AIID API Key (可选)
AIID_API_KEY=

# LLM API配置 (支持腾讯云等 OpenAI 兼容 API)
LLM_API_KEY=
LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/coding/v3
LLM_MODEL=glm-5

# JWT配置
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 管理员账号
ADMIN_EMAIL=admin
ADMIN_PASSWORD=password

# 调试模式
DEBUG=true

# LLM 调用日志配置
LLM_LOG_ENABLED=true
LLM_LOG_DIR=logs/llm

# LLM 批处理配置
LLM_BATCH_SIZE=30
